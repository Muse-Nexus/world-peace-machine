# ─── Supabase (client-side) ───────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id-here

# ─── Supabase (server-side) ───────────────────────────────────────────────────
# ⚠️  These go in Supabase Edge Function secrets, NOT in your local .env
# Supabase Dashboard → Edge Functions → Manage secrets
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # keep this secret
SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# ─── Stripe ───────────────────────────────────────────────────────────────────
# ⚠️  Edge Function secrets only — never expose in client
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# ⚠️  Edge Function secret only
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ─── Lovable ──────────────────────────────────────────────────────────────────
# Only needed if using Lovable's hosted deployment
LOVABLE_API_KEY=

# ─── Checkout ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for Stripe checkout redirects
# Local: http://localhost:5173  |  Prod: https://ivibecodedworldpeace.com
CHECKOUT_ALLOWED_ORIGINS=https://ivibecodedworldpeace.com
